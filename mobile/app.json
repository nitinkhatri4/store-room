{
  "expo": {
    "name": "Storeroom",
    "slug": "storeroom",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "storeroom",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#080909"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080909"
      },
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.yourname.storeroom",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow storeroom to save images to your gallery",
          "savePhotosPermission": "Allow storeroom to save photos",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow storeroom to access your photos"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "69cd3ce5-fad3-4858-8ffe-191551542adf"
      }
    }
  }
}
