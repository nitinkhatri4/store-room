{
  "expo": {
    "name": "Storeroom",
    "slug": "storeroom",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "storeroom",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.yourname.storeroom",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#080909"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080909",
          "image": "./assets/splash-logo.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#080909",
            "image": "./assets/splash-logo.png"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow storeroom to save images to your gallery",
          "savePhotosPermission": "Allow storeroom to save photos",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow storeroom to access your photos"
        }
      ]
    ]
  }
}
